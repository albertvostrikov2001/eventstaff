# =============================================
# Unity Platform — Environment Variables
# =============================================
# Copy to .env and fill in actual values:
#   cp .env.example .env

# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://unity:unity_secret@localhost:5432/unity_db?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- JWT Authentication ----
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ---- S3 / Yandex Object Storage ----
S3_ENDPOINT="https://storage.yandexcloud.net"
S3_REGION="ru-central1"
S3_BUCKET="unity-uploads"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ---- Payments: YooKassa ----
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_RETURN_URL="http://localhost:3000/payment/success"

# ---- Email: Resend ----
RESEND_API_KEY=""
EMAIL_FROM="noreply@unity-staff.ru"

# ---- SMS (SMS.ru) ----
SMS_API_KEY=""

# ---- Yandex Maps ----
YANDEX_MAPS_API_KEY=""

# ---- OAuth: Google ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- OAuth: VK ----
VK_CLIENT_ID=""
VK_CLIENT_SECRET=""

# ---- Next.js public ----
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_WS_URL="http://localhost:4000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""

# ---- NextAuth (if used) ----
NEXTAUTH_SECRET="change-me-to-a-random-string"

# ---- Sentry ----
SENTRY_DSN=""

# ---- PostHog Analytics ----
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ---- Node environment ----
NODE_ENV="development"

# ---- API Server ----
API_PORT=4000
API_HOST="0.0.0.0"

# ---- Web Server ----
WEB_PORT=3000
