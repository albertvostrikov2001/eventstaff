# =============================================
# Unity Platform — Environment Variables
# =============================================
# Copy to .env and fill in actual values:
#   cp .env.example .env
# Локально: Docker Desktop → pnpm docker:db (Postgres+Redis), затем pnpm db:push и pnpm dev:all.
# Полный стек в Docker: pnpm docker:up (тогда API уже в контейнере — не запускайте второй API на :4000).

# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://unity:unity_secret@localhost:5432/unity_db?schema=public"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- JWT Authentication ----
# Тот же JWT_SECRET должен быть на Vercel (middleware Next.js проверяет access_token)
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ---- Локальные загрузки (Nginx раздаёт /uploads, не Node) ----
UPLOADS_ROOT="/opt/app/uploads"
PUBLIC_UPLOADS_BASE_URL="https://yourdomain.ru/uploads"

# ---- S3 / Yandex Object Storage ----
S3_ENDPOINT="https://storage.yandexcloud.net"
S3_REGION="ru-central1"
S3_BUCKET="unity-uploads"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ---- Payments: YooKassa ----
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
# Секрет в URL вебхука (?secret=) при необходимости; если пусто — проверка отключена (только dev)
YOOKASSA_WEBHOOK_SECRET=""
# URL возврата плательщика после YooKassa
PAYMENT_RETURN_URL="http://localhost:3000/payment/return"

# Админ-почта для заявок и системных писем
ADMIN_EMAIL="admin@yourdomain.ru"

# ---- Email: Resend ----
RESEND_API_KEY=""
# Отправитель (домен должен быть верифицирован в Resend)
RESEND_FROM_EMAIL="noreply@yourdomain.ru"
RESEND_FROM_NAME="Юнити"
# Совместимость со старыми конфигами; если задано, используется при отсутствии RESEND_FROM_EMAIL
EMAIL_FROM="noreply@unity-staff.ru"
# Базовый URL сайта — единый источник правды для ссылок в письмах, API и фронтенда.
# Приоритет: SITE_URL → PUBLIC_SITE_URL → NEXT_PUBLIC_SITE_URL
SITE_URL="http://localhost:3000"
# Устаревшие алиасы (обратная совместимость) — предпочитайте SITE_URL:
# PUBLIC_SITE_URL="http://localhost:3000"

# ---- SMS (SMS.ru) ----
SMS_API_KEY=""

# ---- Yandex Maps ----
YANDEX_MAPS_API_KEY=""

# ---- OAuth: Google ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- OAuth: VK ----
VK_CLIENT_ID=""
VK_CLIENT_SECRET=""

# ---- Next.js public ----
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
# Опционально: если WebSocket на другом хосте, чем из NEXT_PUBLIC_API_URL; иначе клиент чат
# строит origin из NEXT_PUBLIC_API_URL (см. getApiOriginForSocket)
NEXT_PUBLIC_WS_URL="http://localhost:4000"
# NEXT_PUBLIC_SOCKET_URL=https://api.yourdomain.ru
# NEXT_PUBLIC_MEDIA_URL=https://api.yourdomain.ru
NEXT_PUBLIC_SITE_URL=https://yourdomain.ru
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=""

# ---- Next.js: статический экспорт (GitHub Pages) — см. next.config.js ----
# STATIC_EXPORT="false"
# NEXT_PUBLIC_BASE_PATH=""

# ---- NextAuth (if used) ----
NEXTAUTH_SECRET="change-me-to-a-random-string"

# ---- Sentry ----
SENTRY_DSN=""

# ---- PostHog Analytics ----
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ---- CORS (только API; перечислите origin через запятую, без пробелов) ----
# Пример: https://app.vercel.app,https://your-preview.vercel.app
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ---- Кросс-сайт cookies (GitHub Pages + API на другом домене, production) ----
# AUTH_CROSS_SITE_COOKIES="true"
# или: AUTH_COOKIE_SAME_SITE="none"

# ---- Node environment ----
NODE_ENV="development"

# ---- API Server ----
API_PORT=4000
API_HOST="0.0.0.0"

# ---- Web Server ----
WEB_PORT=3000
