# Скопируйте этот файл как .env.local в ЭТОЙ же папке (packages/web):
#   copy env.docker.local.example .env.local
#
# Значения совпадают с docker-compose.yml → сервис api (JWT для middleware Next.js).

JWT_SECRET=local-docker-change-me-to-random-string
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
