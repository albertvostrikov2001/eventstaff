{
  "name": "unity",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=@unity/web",
    "dev:all": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "pnpm --filter @unity/api prisma generate",
    "db:migrate": "pnpm --filter @unity/api prisma migrate dev",
    "db:push": "pnpm --filter @unity/api prisma db push",
    "db:studio": "pnpm --filter @unity/api prisma studio",
    "db:seed": "pnpm --filter @unity/api prisma db seed",
    "clean": "turbo clean && rimraf node_modules",
    "docker:up": "docker compose -f docker-compose.yml -f docker-compose.local.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.local.yml down"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
